# F5-TTS - Build from local project, Gradio 3.x, run inference by default
FROM pytorch/pytorch:2.4.0-cuda12.4-cudnn9-devel

USER root
ARG DEBIAN_FRONTEND=noninteractive

# System deps (ffmpeg for audio; sox optional)
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        wget curl git openssl libssl-dev build-essential \
        ffmpeg libsndfile1-dev sox libsox-fmt-all \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

WORKDIR /workspace

# Copy project (use .dockerignore to exclude large/data folders)
COPY . /workspace/F5-TTS/
WORKDIR /workspace/F5-TTS

# Pin Gradio to 3.x (show_api and API compatibility) AND pin web stack.
# Newer FastAPI/Starlette/Jinja2 combos can break Gradio 3.x templates at runtime.
RUN pip install --no-cache-dir \
        "gradio==3.50.2" \
        "fastapi==0.103.2" \
        "starlette==0.27.0" \
        "jinja2==3.1.4" \
        "pydantic<2.0.0" \
    && pip install -e . --no-cache-dir \
    && pip uninstall -y torchaudio torch || true \
    && pip install --no-cache-dir --force-reinstall --index-url https://download.pytorch.org/whl/cu124 \
        "torch==2.4.0" \
        "torchaudio==2.4.0" \
    && pip install --no-cache-dir tensorboard

RUN python -c "import torch, torchaudio; print('torch', torch.__version__, 'cuda', torch.version.cuda); print('torchaudio', torchaudio.__version__)"

# Optional: init submodules if BigVGAN is needed
# RUN git submodule update --init --recursive || true

# Workspace: montar no run com -v %cd%\ckpts:/workspace/F5-TTS/ckpts e -v %cd%\data:/workspace/F5-TTS/data
RUN mkdir -p /workspace/F5-TTS/ckpts /workspace/F5-TTS/data

EXPOSE 7860
ENV SHELL=/bin/bash
ENV F5TTS_WORKSPACE=/workspace/F5-TTS
ENV F5TTS_CKPTS=/workspace/F5-TTS/ckpts
ENV F5TTS_DATA=/workspace/F5-TTS/data

# Default: run inference Gradio; override for finetune: docker run ... f5-tts_finetune-gradio --host 0.0.0.0
CMD ["f5-tts_infer-gradio", "--host", "0.0.0.0", "--port", "7860"]
